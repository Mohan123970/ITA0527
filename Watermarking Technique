import cv2

img = cv2.imread(r"C:\Users\mohan\OneDrive\Pictures\wp6334597-jr-ntr-mobile-hd-wallpapers.png")
watermark = cv2.imread(r"C:\Users\mohan\OneDrive\Pictures\images.jpeg")

watermark = cv2.resize(watermark, (200,100))

h, w, c = watermark.shape

roi = img[0:h, 0:w]


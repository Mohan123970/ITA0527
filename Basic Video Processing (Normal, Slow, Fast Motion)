import cv2

cap = cv2.VideoCapture(r"C:\Users\mohan\Downloads\moving_man_10sec.mp4")

while cap.isOpened():
    ret, frame = cap.read()
    if not ret:
        break

    cv2.imshow("Video", frame)

    # Change delay value:
    # 100 = slow motion
    # 30  = normal speed
    # 5   = fast motion
    if cv2.waitKey(30) & 0xFF == ord('q'):
        break

cap.release()
cv2.destroyAllWindows()
